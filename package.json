{
  "name": "artist-owned-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#artist-config-schema": "./shared/schemas/artistConfig.ts"
  },
  "description": "An open-source, Codex-operable web platform for one artist and their audience.",
  "license": "AGPL-3.0-or-later",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.11.0 <25",
    "npm": ">=11.6.0 <12"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:db": "node scripts/test-database.mjs",
    "test:policies": "node scripts/test-policies.mjs",
    "test:spine": "node scripts/test-spine.mjs",
    "test:oauth": "node scripts/run-oauth-test.mjs",
    "test:administration": "node scripts/test-administration.mjs",
    "test:catalog": "node scripts/test-catalog.mjs",
    "test:media": "node scripts/test-media-worker.mjs",
    "test:media-import": "node scripts/test-media-import.mjs",
    "test:commerce": "node scripts/test-commerce.mjs",
    "test:stripe-signature": "node --experimental-strip-types scripts/test-stripe-signature.mjs",
    "test:licensing": "node scripts/test-licensing.mjs",
    "test:learning": "node --experimental-strip-types scripts/test-learning.mjs",
    "test:telemetry": "node scripts/test-telemetry.mjs",
    "test:setup": "node --experimental-strip-types scripts/test-setup.ts",
    "test:portability": "node --experimental-strip-types scripts/test-portability.ts",
    "test:hardening": "node scripts/run-production-hardening.mjs",
    "test:performance": "node scripts/test-performance.mjs",
    "test:recovery": "node scripts/test-recovery.mjs",
    "test:hosted-reset": "node scripts/test-hosted-reset.mjs",
    "test:services": "node scripts/test-vercel-services.mjs",
    "test:vercel-bootstrap": "node scripts/test-vercel-first-deployment-bootstrap.mjs",
    "test:docs": "node scripts/test-documentation.mjs",
    "test:cross-browser": "node scripts/run-cross-browser.mjs",
    "test:browser-secrets": "node scripts/check-browser-secrets.mjs",
    "test:e2e": "node scripts/run-e2e.mjs",
    "setup:preflight": "node scripts/setup-preflight.mjs",
    "setup:documents": "node scripts/setup-document-runtime.mjs",
    "setup:interview": "node --experimental-strip-types scripts/setup-interview.ts",
    "setup:preview": "node --experimental-strip-types scripts/setup-preview.ts",
    "setup:apply": "node --experimental-strip-types scripts/setup-apply.ts",
    "setup:local": "node scripts/setup-local.mjs",
    "setup:check": "node --experimental-strip-types scripts/setup-check.mjs",
    "export:artist": "node --experimental-strip-types scripts/export-artist.ts",
    "export:verify": "node --experimental-strip-types scripts/verify-export.ts",
    "restore:check": "node --experimental-strip-types scripts/restore-check.ts",
    "seed:reset": "node scripts/reset-local-demo.mjs",
    "demo:local": "node scripts/demo-local.mjs",
    "demo:reset": "node scripts/reset-local-demo.mjs",
    "hosted:confirmation": "node scripts/hosted-confirmation.mjs",
    "hosted:initialize": "node scripts/hosted-reset.mjs initialize",
    "hosted:check": "node scripts/hosted-reset.mjs check",
    "hosted:reset": "node scripts/hosted-reset.mjs reset",
    "hosted:vercel-bootstrap": "node scripts/vercel-first-deployment-bootstrap.mjs",
    "health:check": "node scripts/health-check.mjs",
    "diagnose": "node scripts/diagnose.mjs",
    "media:work": "node --experimental-strip-types workers/media/index.ts --once",
    "media:watch": "node --experimental-strip-types workers/media/index.ts --watch",
    "media:inspect": "node --experimental-strip-types scripts/import-media.ts inspect",
    "media:apply": "node --experimental-strip-types scripts/import-media.ts apply",
    "documents:work": "node --experimental-strip-types workers/documents/index.ts --once",
    "documents:watch": "node --experimental-strip-types workers/documents/index.ts --watch",
    "verify:foundation": "node scripts/verify-foundation.mjs",
    "verify:spine": "node scripts/verify-spine.mjs && npm run test:oauth",
    "verify:administration": "node scripts/verify-administration.mjs",
    "verify:catalog": "npm run setup:local && npm run test:policies && npm run test:catalog && npm run test:media && npm run test:media-import && npm run test:browser-secrets",
    "verify:commerce": "npm run setup:local && npm run test:policies && npm run test:commerce && npm run test:stripe-signature && npm run test:browser-secrets",
    "verify:licensing": "npm run setup:local && npm run test:policies && npm run test:licensing && npm run test:browser-secrets",
    "verify:learning": "npm run setup:local && npm run test:policies && npm run test:learning && npm run test:browser-secrets",
    "verify:telemetry": "npm run setup:local && npm run test:policies && npm run test:telemetry && npm run test:browser-secrets",
    "verify:setup": "npm run setup:local && npm run test:setup && npm run test:browser-secrets",
    "verify:portability": "npm run setup:local && npm run test:portability && npm run test:browser-secrets",
    "verify:hardening": "npm run setup:local && npm run test:unit && npm run test:policies && npm run build && npm run test:hardening && npm run test:browser-secrets",
    "verify:recovery": "npm run test:recovery && npm run test:hosted-reset && npm run test:browser-secrets",
    "verify:package": "npm run test:services && npm run test:vercel-bootstrap && npm run test:docs && npm run test:cross-browser && npm run test:browser-secrets",
    "verify": "npm run verify:foundation && npm run verify:spine && npm run verify:administration && npm run verify:catalog && npm run verify:commerce && npm run verify:licensing && npm run verify:learning && npm run verify:telemetry && npm run verify:setup && npm run verify:portability && npm run verify:hardening && npm run verify:recovery && npm run setup:local && npm run test:spine && npm run test:e2e && npm run verify:package"
  },
  "dependencies": {
    "@nuxt/image": "2.0.0",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@pinia/nuxt": "0.11.3",
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.5",
    "@vercel/functions": "3.7.5",
    "@vueuse/nuxt": "14.3.0",
    "nuxt": "4.4.8",
    "nuxt-security": "2.6.0",
    "pinia": "3.0.4",
    "stripe": "^22.3.1",
    "vue": "3.5.39",
    "vue-router": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@nuxt/eslint": "1.16.0",
    "@nuxt/test-utils": "4.0.3",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "happy-dom": "20.10.6",
    "prettier": "3.9.5",
    "supabase": "2.109.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  }
}

{
  "$schema": "node_modules/wrangler/config-schema.json",
  // Local development only. Sites hosting remains controlled by
  // .openai/hosting.json and the approval-gated Sites hosting workflow.
  "name": "a-op",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-05-15",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "a-op-d1",
      "database_id": "00000000-0000-4000-8000-000000000000",
      "migrations_dir": "./drizzle",
      "migrations_table": "d1_migrations",
      "remote": false,
    },
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "a-op-media",
      "remote": false,
    },
  ],
}

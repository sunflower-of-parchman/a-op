# Public browser configuration
NUXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NUXT_PUBLIC_DEMO_MODE=true
# Optional comma-separated allowlist: google,apple,github,spotify
NUXT_PUBLIC_OAUTH_PROVIDERS=

# Server-only configuration. Never expose these values through public runtime config.
NUXT_SUPABASE_SECRET_KEY=
NUXT_STRIPE_SECRET_KEY=
NUXT_STRIPE_WEBHOOK_SECRET=
# Shared server-only bearer secret for private media and document worker invocations.
NUXT_MEDIA_WORKER_SECRET=

# Optional document-worker identity and Python executable.
LICENSE_DOCUMENT_WORKER_ID=
LICENSE_DOCUMENT_PYTHON=python3

# Optional public origin used by health checks and authentication redirects.
NUXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

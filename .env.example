# Sites commerce is permanently simulated through Stripe Test Mode.
# Use Stripe-provided test credentials only. Live credentials fail validation.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_test_publishable_key
STRIPE_SECRET_KEY=sk_test_replace_with_your_test_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_test_webhook_secret

# Required before a fresh production Site can bootstrap its
# one artist-owner. Replace this with that person's ChatGPT account email.
AOP_OWNER_BOOTSTRAP_EMAIL=replace_with_approved_chatgpt_email

# Optional hosted media request limit in bytes. Accepted range: 1024-67108864.
# MEDIA_PUBLICATION_MAX_BYTES=33554432
